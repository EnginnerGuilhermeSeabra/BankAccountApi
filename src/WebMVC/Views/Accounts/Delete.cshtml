@model TES.Application.Accounts.DTOs.AccountDto

@{
    ViewData["Title"] = "Excluir Conta";
}

<div class="row justify-content-center mb-5">
    <div class="col-lg-8">
        <div class="d-flex align-items-center mb-4">
            <div class="me-3">
                <i class="bi bi-exclamation-triangle-fill display-4 text-danger"></i>
            </div>
            <div>
                <h1>@ViewData["Title"]</h1>
                <p class="text-muted mb-0">Esta ação é irreversível</p>
            </div>
        </div>

        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-lg"></i>
            <strong> Atenção!</strong>
            <p class="mb-0 mt-2">
                Você está prestes a excluir permanentemente a conta de <strong>@Model.NomeTitular</strong>. 
                Esta ação não pode ser desfeita.
            </p>
        </div>

        <div class="card border-danger border-2 mb-4">
            <div class="card-body p-4">
                <h5 class="mb-3">Detalhes da Conta</h5>
                <dl class="row">
                    <dt class="col-sm-4">Nome Titular:</dt>
                    <dd class="col-sm-8 mb-3">
                        <strong>@Model.NomeTitular</strong>
                    </dd>

                    <dt class="col-sm-4">CPF:</dt>
                    <dd class="col-sm-8 mb-3">
                        <code>@Model.Cpf</code>
                    </dd>

                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8 mb-3">
                        @{
                            var statusBadge = Model.Status switch
                            {
                                TES.Domain.Accounts.Enums.AccountStatus.Ativa => ("success", "Ativa"),
                                TES.Domain.Accounts.Enums.AccountStatus.Inativa => ("secondary", "Inativa"),
                                _ => ("secondary", "Desconhecido")
                            };
                        }
                        <span class="badge bg-@statusBadge.Item1">@statusBadge.Item2</span>
                    </dd>

                    <dt class="col-sm-4">Criado em:</dt>
                    <dd class="col-sm-8">
                        @Model.CriadoEm.ToString("dd/MM/yyyy HH:mm:ss")
                    </dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <div class="d-grid gap-2 d-sm-flex justify-content-sm-between">
                <button type="submit" class="btn btn-danger btn-lg">
                    <i class="bi bi-trash"></i> Confirmar Exclusão
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
            </div>
        </form>

        <div class="alert alert-warning mt-4" role="alert">
            <i class="bi bi-info-circle"></i>
            <strong> Importante:</strong>
            <ul class="mb-0 mt-2">
                <li>Esta ação deletará a conta permanentemente</li>
                <li>Nenhum backup será mantido</li>
                <li>O ID será reutilizável para novas contas</li>
            </ul>
        </div>
    </div>
</div>
