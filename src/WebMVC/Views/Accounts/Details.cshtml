@model TES.Application.Accounts.DTOs.AccountDto
@using TES.Domain.Accounts.Enums

@{
    ViewData["Title"] = $"Conta - {Model.NomeTitular}";
}

<div class="row mb-5">
    <div class="col-lg-8">
        <div class="d-flex align-items-center mb-4">
            <div class="me-3">
                <i class="bi bi-credit-card2-front display-4 text-primary"></i>
            </div>
            <div>
                <h1>Detalhes da Conta</h1>
                <p class="text-muted mb-0">@Model.NomeTitular</p>
            </div>
        </div>

        <div class="card border-0 shadow">
            <div class="card-body p-4">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">
                            <i class="bi bi-person-circle"></i> Nome do Titular
                        </h6>
                        <p class="h5 fw-bold">@Model.NomeTitular</p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">
                            <i class="bi bi-card-text"></i> CPF
                        </h6>
                        <p class="h5 fw-bold">@Model.Cpf</p>
                    </div>
                </div>

                <hr>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">
                            <i class="bi bi-toggle2-on"></i> Status da Conta
                        </h6>
                        <p class="mb-0">
                            @{
                                var statusBadge = Model.Status switch
                                {
                                    AccountStatus.Ativa => ("success", "Ativa"),
                                    AccountStatus.Inativa => ("secondary", "Inativa"),
                                    _ => ("secondary", "Desconhecido")
                                };
                            }
                            <span class="badge bg-@statusBadge.Item1" style="font-size: 0.875rem; padding: 0.5rem 1rem;">
                                <i class="bi bi-circle-fill"></i> @statusBadge.Item2
                            </span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">
                            <i class="bi bi-check-circle"></i> ID da Conta
                        </h6>
                        <p class="small font-monospace">
                            <code>@Model.Id</code>
                        </p>
                    </div>
                </div>

                <hr>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">
                            <i class="bi bi-activity"></i> Último Evento
                        </h6>
                        <p class="mb-0">
                            @{
                                var (eventColor, eventIcon, eventLabel) = Model.LastEvent switch
                                {
                                    AccountEvent.Created => ("success", "bi-plus-circle", "Criado"),
                                    AccountEvent.Updated => ("warning", "bi-pencil", "Atualizado"),
                                    AccountEvent.Deleted => ("danger", "bi-trash", "Excluído"),
                                    _ => ("secondary", "bi-question-circle", "Desconhecido")
                                };
                            }
                            <span class="badge bg-@eventColor" style="font-size: 0.875rem; padding: 0.5rem 1rem;">
                                <i class="bi @eventIcon"></i> @eventLabel
                            </span>
                        </p>
                    </div>
                </div>

                <hr>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">
                            <i class="bi bi-calendar-event"></i> Criado em
                        </h6>
                        <p class="mb-0">
                            @Model.CriadoEm.ToString("dd/MM/yyyy")
                            <br>
                            <small class="text-muted">@Model.CriadoEm.ToString("HH:mm:ss")</small>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted mb-2">
                            <i class="bi bi-clock-history"></i> Último Update
                        </h6>
                        <p class="mb-0">
                            @if (Model.AtualizadoEm.HasValue)
                            {
                                <span>@Model.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm:ss")</span>
                            }
                            else
                            {
                                <span class="text-muted">Sem atualizações ainda</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg">
                <i class="bi bi-pencil-square"></i> Editar
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-lg">
                <i class="bi bi-trash"></i> Excluir
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    <!-- Info Section -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm bg-light mb-3">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="bi bi-info-circle"></i> Informações Úteis
                </h6>
                <ul class="list-unstyled small">
                    <li class="mb-2"><i class="bi bi-check-lg text-success"></i> Conta criada com sucesso</li>
                    <li class="mb-2"><i class="bi bi-pencil"></i> Você pode editar os dados da conta</li>
                    <li><i class="bi bi-trash"></i> A exclusão é irreversível</li>
                </ul>
            </div>
        </div>
    </div>
</div>
