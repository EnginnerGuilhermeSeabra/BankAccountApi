@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="row mb-5">
    <div class="col-12">
        <div class="bg-gradient p-5 rounded-3 text-white text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <h1 class="display-3 fw-bold mb-3">
                <i class="bi bi-bank2"></i> Bem-vindo ao TES
            </h1>
            <p class="lead mb-4">Sistema Inteligente de Gerenciamento de Contas Bancárias</p>
            <a href="@Url.Action("Index", "Accounts")" class="btn btn-light btn-lg">
                <i class="bi bi-arrow-right-circle"></i> Gerenciar Contas
            </a>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="row g-4 mb-5">
    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm hover-shadow">
            <div class="card-body text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-credit-card display-4 text-primary"></i>
                </div>
                <h5 class="card-title">Criar Contas</h5>
                <p class="card-text">Abra novas contas bancárias com facilidade e segurança.</p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm hover-shadow">
            <div class="card-body text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-eye display-4 text-success"></i>
                </div>
                <h5 class="card-title">Visualizar Dados</h5>
                <p class="card-text">Acesse informações detalhadas de todas as contas.</p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm hover-shadow">
            <div class="card-body text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-pencil-square display-4 text-warning"></i>
                </div>
                <h5 class="card-title">Atualizar</h5>
                <p class="card-text">Modifique dados e status de contas existentes.</p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card h-100 border-0 shadow-sm hover-shadow">
            <div class="card-body text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-trash display-4 text-danger"></i>
                </div>
                <h5 class="card-title">Excluir</h5>
                <p class="card-text">Remova contas com segurança e confirmação.</p>
            </div>
        </div>
    </div>
</div>

<!-- Tech Stack Section -->
<div class="row mb-5">
    <div class="col-12">
        <div class="bg-light p-5 rounded-3">
            <h2 class="mb-4">
                <i class="bi bi-gear"></i> Tecnologias Utilizadas
            </h2>
            <div class="row g-3">
                <div class="col-md-3 col-sm-6">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-cpu text-primary me-3" style="font-size: 1.5rem;"></i>
                        <div>
                            <strong>.NET 8.0</strong>
                            <br>
                            <small class="text-muted">Framework Moderno</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-diagram-3 text-success me-3" style="font-size: 1.5rem;"></i>
                        <div>
                            <strong>MVC Architecture</strong>
                            <br>
                            <small class="text-muted">Padrão Robusto</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-database text-warning me-3" style="font-size: 1.5rem;"></i>
                        <div>
                            <strong>Entity Framework 8</strong>
                            <br>
                            <small class="text-muted">ORM Completo</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-bootstrap-fill text-danger me-3" style="font-size: 1.5rem;"></i>
                        <div>
                            <strong>Bootstrap 5</strong>
                            <br>
                            <small class="text-muted">UI Responsiva</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Call to Action -->
<div class="row mb-5">
    <div class="col-12">
        <div class="bg-primary text-white p-5 rounded-3 text-center">
            <h2 class="mb-4">Comece Agora Mesmo</h2>
            <p class="lead mb-4">Crie sua primeira conta e explore todas as funcionalidades do sistema.</p>
            <div class="btn-group" role="group">
                <a href="@Url.Action("Create", "Accounts")" class="btn btn-light btn-lg">
                    <i class="bi bi-plus-circle"></i> Nova Conta
                </a>
                <a href="@Url.Action("Index", "Accounts")" class="btn btn-outline-light btn-lg">
                    <i class="bi bi-list"></i> Ver Contas
                </a>
            </div>
        </div>
    </div>
</div>
